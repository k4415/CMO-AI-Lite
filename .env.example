# CMO AI Lite 環境変数（すべて任意）
# 注意: .env ファイルは自動読み込みされません。OS環境変数として設定するか、UIの設定画面でAPIキーを保存してください。

# OpenAI APIキー / Anthropic APIキー（UI設定またはOS環境変数）
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# UIサーバーポート（既定 5173）
PORT=

# テキスト生成モデル上書き（既定 gpt-5.5）
CMOAI_TEXT_MODEL=

# バナー copyplan 専用モデル（既定 claude-opus-4-8）
CMOAI_BANNER_COPY_MODEL=

# バナー copyplan のタイムアウト（ミリ秒）
CMOAI_BANNER_COPY_TIMEOUT_MS=

# バナー copyplan の思考深度（例: high / xhigh）
CMOAI_BANNER_COPY_EFFORT=

# バナー画像生成の同時実行数
CMOAI_IMAGE_CONCURRENCY=

# LPスクリーンショット用Chrome/Edgeのパス
CHROME_PATH=

# LPスクリーンショット文字起こしの枚数上限
CMOAI_LP_TRANSCRIBE_MAX_SLICES=

# OCRモード
CMOAI_OCR_MODE=

# Gemini APIキー（OCR等で使用する場合）
GEMINI_API_KEY=
